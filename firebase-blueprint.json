{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User account registration and preferences",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "createdAt"]
    },
    "ChatMessage": {
      "title": "Chat Message",
      "description": "A conversation log message with Sohid AI",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "sender": { "type": "string", "enum": ["user", "ai"] },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "sender", "text", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/users/{userId}/messages/{messageId}": {
      "schema": "ChatMessage",
      "description": "Conversations with SOHID AI"
    }
  }
}
